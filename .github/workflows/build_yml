name: Build USART Firmware

on:
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-22.04
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: '3.11'
      - name: Install PlatformIO
        run: pip install platformio
      - name: Build VARIANT_USART
        run: pio run -e VARIANT_USART
      - name: Upload firmware
        uses: actions/upload-artifact@v4
        with:
          name: firmware-USART
          path: .pio/build/VARIANT_USART/*.bin
